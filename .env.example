# MCUVerse AI Configuration

# Database
DATABASE_URL=sqlite:///./mcuverse.db

# Cache (memory | sqlite | redis)
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379/0

# Embeddings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
FAISS_INDEX_PATH=embeddings/faiss_index

# LLM Provider (gemini | openai | anthropic | groq | ollama | retrieval_only)
LLM_PROVIDER=retrieval_only
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_URL=http://localhost:11434

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional production services
# DATABASE_URL=postgresql+psycopg2://mcuverse:mcuverse@postgres:5432/mcuverse
# CACHE_PROVIDER=redis
# REDIS_URL=redis://redis:6379/0
